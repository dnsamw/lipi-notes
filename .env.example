# Database — supply a Neon or local PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/lipinotes

# Auth.js v5 — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
AUTH_SECRET=your-secret-here

# Your app URL (use http://localhost:3000 for development)
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# Google OAuth — create at https://console.cloud.google.com
# Add Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: Google Drive backup scope is requested at runtime, no extra vars needed
